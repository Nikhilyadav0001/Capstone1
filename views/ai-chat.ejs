<%- include('partials/header') %>

<div class="container" style="max-width: 900px; padding-top: 2rem; height: calc(100vh - 150px); display: flex; flex-direction: column;">
    <div class="glass-card animate-fade" style="flex: 1; display: flex; flex-direction: column; overflow: hidden; padding: 0;">
        <!-- Chat Header -->
        <div style="padding: 1.5rem; border-bottom: 1px solid var(--glass-border); display: flex; align-items: center; gap: 1rem;">
            <div style="width: 40px; height: 40px; background: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-robot"></i>
            </div>
            <div>
                <h2 style="font-size: 1.2rem;">AI Travel Assistant</h2>
                <p style="font-size: 0.8rem; color: #22c55e;"><i class="fas fa-circle" style="font-size: 0.5rem;"></i> Online & Ready to help</p>
            </div>
        </div>

        <!-- Chat Messages -->
        <div id="chatMessages" style="flex: 1; overflow-y: auto; padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
            <div style="align-self: flex-start; max-width: 80%; background: var(--glass); padding: 1rem; border-radius: 0 20px 20px 20px; border: 1px solid var(--glass-border);">
                Hello! I'm your AI Travel Guide. Ask me anything about your next destination, packing tips, or local customs!
            </div>
        </div>

        <!-- Chat Input -->
        <div style="padding: 1.5rem; border-top: 1px solid var(--glass-border); background: rgba(15, 23, 42, 0.3);">
            <form id="chatForm" style="display: flex; gap: 1rem;">
                <input type="text" id="userInput" placeholder="Ask about Kyoto, packing lists, hidden gems..." 
                    style="flex: 1; background: rgba(15, 23, 42, 0.5); border: 1px solid var(--glass-border); padding: 1rem; border-radius: 12px; color: white; outline: none;">
                <button type="submit" class="btn btn-primary" style="padding: 0 1.5rem;">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    const chatForm = document.getElementById('chatForm');
    const userInput = document.getElementById('userInput');
    const chatMessages = document.getElementById('chatMessages');

    function appendMessage(text, isUser = false) {
        const msg = document.createElement('div');
        msg.style.alignSelf = isUser ? 'flex-end' : 'flex-start';
        msg.style.maxWidth = '80%';
        msg.style.padding = '1rem';
        msg.style.borderRadius = isUser ? '20px 0 20px 20px' : '0 20px 20px 20px';
        msg.style.background = isUser ? 'var(--primary)' : 'var(--glass)';
        msg.style.border = '1px solid var(--glass-border)';
        msg.style.color = 'white';
        msg.innerText = text;
        chatMessages.appendChild(msg);
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    chatForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const text = userInput.value.trim();
        if (!text) return;

        appendMessage(text, true);
        userInput.value = '';

        // Simulate AI thinking
        const thinking = document.createElement('div');
        thinking.style.alignSelf = 'flex-start';
        thinking.style.color = 'var(--text-muted)';
        thinking.style.fontSize = '0.8rem';
        thinking.innerText = 'AI is thinking...';
        chatMessages.appendChild(thinking);

        try {
            // For now, using the tips endpoint as a general chat fallback
            const response = await fetch('/ai/tips', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ city: text, style: 'balanced' })
            });
            const data = await response.json();
            
            chatMessages.removeChild(thinking);
            
            if (data.success) {
                if (data.tips.mock) {
                   appendMessage(data.tips.message);
                } else if (Array.isArray(data.tips)) {
                    const tipText = data.tips.map(t => `${t.name}: ${t.description}`).join('\n\n');
                    appendMessage(tipText);
                } else {
                    appendMessage(JSON.stringify(data.tips));
                }
            } else {
                appendMessage('Sorry, I encountered an error. Please try again.');
            }
        } catch (err) {
            chatMessages.removeChild(thinking);
            appendMessage('Connection failed.');
        }
    });
</script>

<%- include('partials/footer') %>
