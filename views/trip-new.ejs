<%- include('partials/header') %>

<div class="container" style="max-width: 800px; padding-top: 5rem; padding-bottom: 5rem;">
    <!-- Decorative background elements -->
    <div style="position: fixed; top: 10%; right: 10%; width: 300px; height: 300px; background: var(--primary); filter: blur(150px); opacity: 0.15; z-index: -1;"></div>
    <div style="position: fixed; bottom: 10%; left: 10%; width: 300px; height: 300px; background: #ec4899; filter: blur(150px); opacity: 0.15; z-index: -1;"></div>

    <div class="glass-card animate-fade" style="padding: 3rem; border-radius: 32px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);">
        <div style="text-align: center; margin-bottom: 3rem;">
            <div style="width: 80px; height: 80px; background: linear-gradient(135deg, var(--primary), #ec4899); border-radius: 20px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; transform: rotate(-5deg); box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);">
                <i class="fas fa-map-marked-alt fa-2x" style="color: white; transform: rotate(5deg);"></i>
            </div>
            <h1 style="font-size: 2.5rem; font-weight: 800; background: linear-gradient(to right, #fff, #94a3b8); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Plan Your Escape</h1>
            <p style="color: var(--text-muted); font-size: 1.1rem;">Where will your curiosity take you next?</p>
        </div>
        
        <% if (locals.error) { %>
            <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #fca5a5; padding: 1.2rem; border-radius: 16px; margin-bottom: 2rem; display: flex; align-items: center; gap: 1rem;" class="animate-fade">
                <i class="fas fa-exclamation-circle"></i>
                <%= error %>
            </div>
        <% } %>

        <form action="/travel" method="POST" style="display: grid; gap: 2rem;">
            <!-- Destination -->
            <div class="form-group">
                <label style="display: block; margin-bottom: 0.8rem; color: #94a3b8; font-weight: 500; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em;">Destination</label>
                <div style="position: relative;">
                    <i class="fas fa-location-dot" style="position: absolute; left: 1.2rem; top: 50%; transform: translateY(-50%); color: var(--primary);"></i>
                    <input type="text" name="destination" placeholder="e.g. Bali, Indonesia" required 
                        style="width: 100%; background: rgba(15, 23, 42, 0.6); border: 1px solid var(--glass-border); padding: 1.2rem 1.2rem 1.2rem 3.5rem; border-radius: 16px; color: white; outline: none; transition: all 0.3s ease; font-size: 1.1rem;"
                        onfocus="this.style.borderColor='var(--primary)'; this.style.boxShadow='0 0 0 4px rgba(99, 102, 241, 0.1)'"
                        onblur="this.style.borderColor='var(--glass-border)'; this.style.boxShadow='none'">
                </div>
            </div>
            
            <!-- Dates Row -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                <div class="form-group">
                    <label style="display: block; margin-bottom: 0.8rem; color: #94a3b8; font-weight: 500; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em;">Departure</label>
                    <div style="position: relative;">
                        <i class="fas fa-calendar-alt" style="position: absolute; left: 1.2rem; top: 50%; transform: translateY(-50%); color: var(--primary);"></i>
                        <input type="date" name="startDate" required 
                            style="width: 100%; background: rgba(15, 23, 42, 0.6); border: 1px solid var(--glass-border); padding: 1.2rem 1.2rem 1.2rem 3.5rem; border-radius: 16px; color: white; outline: none; transition: all 0.3s ease; font-size: 1rem;"
                            onfocus="this.style.borderColor='var(--primary)'"
                            onblur="this.style.borderColor='var(--glass-border)'">
                    </div>
                </div>
                <div class="form-group">
                    <label style="display: block; margin-bottom: 0.8rem; color: #94a3b8; font-weight: 500; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em;">Return</label>
                    <div style="position: relative;">
                        <i class="fas fa-calendar-check" style="position: absolute; left: 1.2rem; top: 50%; transform: translateY(-50%); color: var(--primary);"></i>
                        <input type="date" name="endDate" required 
                            style="width: 100%; background: rgba(15, 23, 42, 0.6); border: 1px solid var(--glass-border); padding: 1.2rem 1.2rem 1.2rem 3.5rem; border-radius: 16px; color: white; outline: none; transition: all 0.3s ease; font-size: 1rem;"
                            onfocus="this.style.borderColor='var(--primary)'"
                            onblur="this.style.borderColor='var(--glass-border)'">
                    </div>
                </div>
            </div>

            <!-- Travelers -->
            <div class="form-group">
                <label style="display: block; margin-bottom: 0.8rem; color: #94a3b8; font-weight: 500; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em;">Number of Travelers</label>
                <div style="position: relative;">
                    <i class="fas fa-users" style="position: absolute; left: 1.2rem; top: 50%; transform: translateY(-50%); color: var(--primary);"></i>
                    <input type="number" name="travelers" value="1" min="1" 
                        style="width: 100%; background: rgba(15, 23, 42, 0.6); border: 1px solid var(--glass-border); padding: 1.2rem 1.2rem 1.2rem 3.5rem; border-radius: 16px; color: white; outline: none; transition: all 0.3s ease; font-size: 1.1rem;"
                        onfocus="this.style.borderColor='var(--primary)'"
                        onblur="this.style.borderColor='var(--glass-border)'">
                </div>
            </div>

            <!-- Cost Breakdown Section -->
            <div style="background: rgba(99, 102, 241, 0.1); border: 1px solid rgba(99, 102, 241, 0.2); padding: 1.5rem; border-radius: 20px; margin: 1rem 0;">
                <div style="display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1.5rem;">
                    <i class="fas fa-calculator" style="color: var(--primary); font-size: 1.3rem;"></i>
                    <h3 style="color: white; font-weight: 600; margin: 0;">Trip Cost Breakdown</h3>
                </div>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                    <div>
                        <label style="display: block; margin-bottom: 0.5rem; color: #cbd5e1; font-size: 0.85rem; font-weight: 500;">Flights (USD)</label>
                        <input type="number" name="costFlights" placeholder="0" min="0" step="0.01"
                            style="width: 100%; background: rgba(15, 23, 42, 0.8); border: 1px solid var(--glass-border); padding: 0.8rem; border-radius: 12px; color: white; outline: none; font-size: 0.95rem;"
                            onfocus="this.style.borderColor='var(--primary)'"
                            onblur="this.style.borderColor='var(--glass-border)'">
                    </div>
                    <div>
                        <label style="display: block; margin-bottom: 0.5rem; color: #cbd5e1; font-size: 0.85rem; font-weight: 500;">Accommodation (USD)</label>
                        <input type="number" name="costAccommodation" placeholder="0" min="0" step="0.01"
                            style="width: 100%; background: rgba(15, 23, 42, 0.8); border: 1px solid var(--glass-border); padding: 0.8rem; border-radius: 12px; color: white; outline: none; font-size: 0.95rem;"
                            onfocus="this.style.borderColor='var(--primary)'"
                            onblur="this.style.borderColor='var(--glass-border)'">
                    </div>
                    <div>
                        <label style="display: block; margin-bottom: 0.5rem; color: #cbd5e1; font-size: 0.85rem; font-weight: 500;">Food & Dining (USD)</label>
                        <input type="number" name="costFood" placeholder="0" min="0" step="0.01"
                            style="width: 100%; background: rgba(15, 23, 42, 0.8); border: 1px solid var(--glass-border); padding: 0.8rem; border-radius: 12px; color: white; outline: none; font-size: 0.95rem;"
                            onfocus="this.style.borderColor='var(--primary)'"
                            onblur="this.style.borderColor='var(--glass-border)'">
                    </div>
                    <div>
                        <label style="display: block; margin-bottom: 0.5rem; color: #cbd5e1; font-size: 0.85rem; font-weight: 500;">Activities (USD)</label>
                        <input type="number" name="costActivities" placeholder="0" min="0" step="0.01"
                            style="width: 100%; background: rgba(15, 23, 42, 0.8); border: 1px solid var(--glass-border); padding: 0.8rem; border-radius: 12px; color: white; outline: none; font-size: 0.95rem;"
                            onfocus="this.style.borderColor='var(--primary)'"
                            onblur="this.style.borderColor='var(--glass-border)'">
                    </div>
                    <div>
                        <label style="display: block; margin-bottom: 0.5rem; color: #cbd5e1; font-size: 0.85rem; font-weight: 500;">Transportation (USD)</label>
                        <input type="number" name="costTransportation" placeholder="0" min="0" step="0.01"
                            style="width: 100%; background: rgba(15, 23, 42, 0.8); border: 1px solid var(--glass-border); padding: 0.8rem; border-radius: 12px; color: white; outline: none; font-size: 0.95rem;"
                            onfocus="this.style.borderColor='var(--primary)'"
                            onblur="this.style.borderColor='var(--glass-border)'">
                    </div>
                    <div>
                        <label style="display: block; margin-bottom: 0.5rem; color: #cbd5e1; font-size: 0.85rem; font-weight: 500;">Other (USD)</label>
                        <input type="number" name="costOther" placeholder="0" min="0" step="0.01"
                            style="width: 100%; background: rgba(15, 23, 42, 0.8); border: 1px solid var(--glass-border); padding: 0.8rem; border-radius: 12px; color: white; outline: none; font-size: 0.95rem;"
                            onfocus="this.style.borderColor='var(--primary)'"
                            onblur="this.style.borderColor='var(--glass-border)'">
                    </div>
                </div>
                
                <button type="button" onclick="analyzeCost()" style="width: 100%; background: linear-gradient(135deg, #6366f1, #8b5cf6); border: none; color: white; padding: 0.9rem; border-radius: 12px; font-weight: 600; cursor: pointer; transition: all 0.3s ease; font-size: 0.95rem; margin-top: 0.5rem;"
                    onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 10px 20px rgba(99, 102, 241, 0.3)'"
                    onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'">
                    <i class="fas fa-brain" style="margin-right: 0.6rem;"></i>Get AI Cost Analysis
                </button>
            </div>

            <!-- AI Analysis Result -->
            <div id="costAnalysisResult" style="display: none; background: rgba(34, 197, 94, 0.1); border: 1px solid rgba(34, 197, 94, 0.3); padding: 1.5rem; border-radius: 16px; margin: 1rem 0;">
                <div style="display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1rem;">
                    <i class="fas fa-lightbulb" style="color: #22c55e; font-size: 1.2rem;"></i>
                    <h3 style="color: white; font-weight: 600; margin: 0;">AI Cost Insights</h3>
                </div>
                <div id="analysisContent" style="color: #cbd5e1; line-height: 1.6; white-space: pre-wrap;"></div>
            </div>
            <input type="hidden" name="costAnalysis" id="costAnalysis">

            <button type="submit" class="btn btn-primary" style="padding: 1.2rem; font-size: 1.2rem; margin-top: 1rem; border-radius: 16px; width: 100%; justify-content: center; font-weight: 600; box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.4);">
                Create My Journey <i class="fas fa-arrow-right" style="margin-left: 0.8rem;"></i>
            </button>
        </form>
    </div>
</div>

<script>
async function analyzeCost() {
    const costs = {
        flights: parseFloat(document.querySelector('input[name="costFlights"]').value || 0),
        accommodation: parseFloat(document.querySelector('input[name="costAccommodation"]').value || 0),
        food: parseFloat(document.querySelector('input[name="costFood"]').value || 0),
        activities: parseFloat(document.querySelector('input[name="costActivities"]').value || 0),
        transportation: parseFloat(document.querySelector('input[name="costTransportation"]').value || 0),
        other: parseFloat(document.querySelector('input[name="costOther"]').value || 0),
        destination: document.querySelector('input[name="destination"]').value,
        travelers: parseInt(document.querySelector('input[name="travelers"]').value || 1)
    };
    
    const totalCost = Object.values(costs).reduce((a, b) => !isNaN(b) ? a + b : a, 0) - costs.destination - costs.travelers;
    
    if (totalCost === 0) {
        alert('Please enter at least one cost amount');
        return;
    }
    
    try {
        const response = await fetch('/travel/analyze-cost', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(costs)
        });
        
        const data = await response.json();
        
        if (data.success) {
            document.getElementById('analysisContent').innerText = data.analysis;
            document.getElementById('costAnalysisResult').style.display = 'block';
            document.getElementById('costAnalysis').value = data.analysis;
            
            // Smooth scroll to result
            document.getElementById('costAnalysisResult').scrollIntoView({ behavior: 'smooth' });
        } else {
            alert('Error: ' + (data.error || 'Failed to analyze cost'));
        }
    } catch (error) {
        console.error('Error:', error);
        alert('Failed to analyze cost. Please try again.');
    }
}
</script>

<%- include('partials/footer') %>
