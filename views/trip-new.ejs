<%- include('partials/header') %>

<div class="container" style="max-width: 800px; padding-top: 5rem; padding-bottom: 5rem;">
    <!-- Decorative background elements -->
    <div style="position: fixed; top: 10%; right: 10%; width: 300px; height: 300px; background: var(--primary); filter: blur(150px); opacity: 0.15; z-index: -1;"></div>
    <div style="position: fixed; bottom: 10%; left: 10%; width: 300px; height: 300px; background: #ec4899; filter: blur(150px); opacity: 0.15; z-index: -1;"></div>

    <div class="glass-card animate-fade" style="padding: 3rem; border-radius: 32px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);">
        <div style="text-align: center; margin-bottom: 3rem;">
            <div style="width: 80px; height: 80px; background: linear-gradient(135deg, var(--primary), #ec4899); border-radius: 20px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; transform: rotate(-5deg); box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);">
                <i class="fas fa-map-marked-alt fa-2x" style="color: white; transform: rotate(5deg);"></i>
            </div>
            <h1 style="font-size: 2.5rem; font-weight: 800; background: linear-gradient(to right, #fff, #94a3b8); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Plan Your Escape</h1>
            <p style="color: var(--text-muted); font-size: 1.1rem;">Where will your curiosity take you next?</p>
        </div>
        
        <% if (locals.error) { %>
            <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #fca5a5; padding: 1.2rem; border-radius: 16px; margin-bottom: 2rem; display: flex; align-items: center; gap: 1rem;" class="animate-fade">
                <i class="fas fa-exclamation-circle"></i>
                <%= error %>
            </div>
        <% } %>

        <form action="/travel" method="POST" style="display: grid; gap: 2rem;">
            <!-- Destination -->
            <div class="form-group">
                <label style="display: block; margin-bottom: 0.8rem; color: #94a3b8; font-weight: 500; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em;">Destination</label>
                <div style="position: relative;">
                    <i class="fas fa-location-dot" style="position: absolute; left: 1.2rem; top: 50%; transform: translateY(-50%); color: var(--primary);"></i>
                    <input type="text" name="destination" placeholder="e.g. Bali, Indonesia" required 
                        style="width: 100%; background: rgba(15, 23, 42, 0.6); border: 1px solid var(--glass-border); padding: 1.2rem 1.2rem 1.2rem 3.5rem; border-radius: 16px; color: white; outline: none; transition: all 0.3s ease; font-size: 1.1rem;"
                        onfocus="this.style.borderColor='var(--primary)'; this.style.boxShadow='0 0 0 4px rgba(99, 102, 241, 0.1)'"
                        onblur="this.style.borderColor='var(--glass-border)'; this.style.boxShadow='none'">
                </div>
            </div>
            
            <!-- Dates Row -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                <div class="form-group">
                    <label style="display: block; margin-bottom: 0.8rem; color: #94a3b8; font-weight: 500; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em;">Departure</label>
                    <div style="position: relative;">
                        <i class="fas fa-calendar-alt" style="position: absolute; left: 1.2rem; top: 50%; transform: translateY(-50%); color: var(--primary);"></i>
                        <input type="date" name="startDate" required 
                            style="width: 100%; background: rgba(15, 23, 42, 0.6); border: 1px solid var(--glass-border); padding: 1.2rem 1.2rem 1.2rem 3.5rem; border-radius: 16px; color: white; outline: none; transition: all 0.3s ease; font-size: 1rem;"
                            onfocus="this.style.borderColor='var(--primary)'"
                            onblur="this.style.borderColor='var(--glass-border)'">
                    </div>
                </div>
                <div class="form-group">
                    <label style="display: block; margin-bottom: 0.8rem; color: #94a3b8; font-weight: 500; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em;">Return</label>
                    <div style="position: relative;">
                        <i class="fas fa-calendar-check" style="position: absolute; left: 1.2rem; top: 50%; transform: translateY(-50%); color: var(--primary);"></i>
                        <input type="date" name="endDate" required 
                            style="width: 100%; background: rgba(15, 23, 42, 0.6); border: 1px solid var(--glass-border); padding: 1.2rem 1.2rem 1.2rem 3.5rem; border-radius: 16px; color: white; outline: none; transition: all 0.3s ease; font-size: 1rem;"
                            onfocus="this.style.borderColor='var(--primary)'"
                            onblur="this.style.borderColor='var(--glass-border)'">
                    </div>
                </div>
            </div>

            <!-- Travelers (Now full width since budget is removed) -->
            <div class="form-group">
                <label style="display: block; margin-bottom: 0.8rem; color: #94a3b8; font-weight: 500; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em;">Number of Travelers</label>
                <div style="position: relative;">
                    <i class="fas fa-users" style="position: absolute; left: 1.2rem; top: 50%; transform: translateY(-50%); color: var(--primary);"></i>
                    <input type="number" name="travelers" value="1" min="1" 
                        style="width: 100%; background: rgba(15, 23, 42, 0.6); border: 1px solid var(--glass-border); padding: 1.2rem 1.2rem 1.2rem 3.5rem; border-radius: 16px; color: white; outline: none; transition: all 0.3s ease; font-size: 1.1rem;"
                        onfocus="this.style.borderColor='var(--primary)'"
                        onblur="this.style.borderColor='var(--glass-border)'">
                </div>
            </div>

            <button type="submit" class="btn btn-primary" style="padding: 1.2rem; font-size: 1.2rem; margin-top: 1rem; border-radius: 16px; width: 100%; justify-content: center; font-weight: 600; box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.4);">
                Create My Journey <i class="fas fa-arrow-right" style="margin-left: 0.8rem;"></i>
            </button>
        </form>
    </div>
</div>

<%- include('partials/footer') %>
