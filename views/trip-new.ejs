<%- include('partials/header') %>

<div class="container" style="max-width: 800px; padding-top: 5rem; padding-bottom: 5rem;">
    <!-- Decorative background elements -->
    <div style="position: fixed; top: 10%; right: 10%; width: 300px; height: 300px; background: var(--primary); filter: blur(150px); opacity: 0.15; z-index: -1;"></div>
    <div style="position: fixed; bottom: 10%; left: 10%; width: 300px; height: 300px; background: #ec4899; filter: blur(150px); opacity: 0.15; z-index: -1;"></div>

    <div class="glass-card animate-fade" style="padding: 3rem; border-radius: 32px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);">
        <div style="text-align: center; margin-bottom: 3rem;">
            <div style="width: 80px; height: 80px; background: linear-gradient(135deg, var(--primary), #ec4899); border-radius: 20px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; transform: rotate(-5deg); box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);">
                <i class="fas fa-map-marked-alt fa-2x" style="color: white; transform: rotate(5deg);"></i>
            </div>
            <h1 style="font-size: 2.5rem; font-weight: 800; background: linear-gradient(to right, #fff, #94a3b8); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Plan Your Escape</h1>
            <p style="color: var(--text-muted); font-size: 1.1rem;">Where will your curiosity take you next?</p>
        </div>
        
        <% if (locals.error) { %>
            <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #fca5a5; padding: 1.2rem; border-radius: 16px; margin-bottom: 2rem; display: flex; align-items: center; gap: 1rem;" class="animate-fade">
                <i class="fas fa-exclamation-circle"></i>
                <%= error %>
            </div>
        <% } %>

        <form action="/travel" method="POST" style="display: grid; gap: 2rem;">
            <!-- Destination -->
            <div class="form-group">
                <label style="display: block; margin-bottom: 0.8rem; color: #94a3b8; font-weight: 500; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em;">Destination</label>
                <div style="position: relative;">
                    <i class="fas fa-location-dot" style="position: absolute; left: 1.2rem; top: 50%; transform: translateY(-50%); color: var(--primary);"></i>
                    <input type="text" name="destination" placeholder="e.g. Bali, Indonesia" required 
                        style="width: 100%; background: rgba(15, 23, 42, 0.6); border: 1px solid var(--glass-border); padding: 1.2rem 1.2rem 1.2rem 3.5rem; border-radius: 16px; color: white; outline: none; transition: all 0.3s ease; font-size: 1.1rem;"
                        onfocus="this.style.borderColor='var(--primary)'; this.style.boxShadow='0 0 0 4px rgba(99, 102, 241, 0.1)'"
                        onblur="this.style.borderColor='var(--glass-border)'; this.style.boxShadow='none'">
                </div>
            </div>
            
            <!-- Dates Row -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                <div class="form-group">
                    <label style="display: block; margin-bottom: 0.8rem; color: #94a3b8; font-weight: 500; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em;">Departure</label>
                    <div style="position: relative;">
                        <i class="fas fa-calendar-alt" style="position: absolute; left: 1.2rem; top: 50%; transform: translateY(-50%); color: var(--primary);"></i>
                        <input type="date" name="startDate" required 
                            style="width: 100%; background: rgba(15, 23, 42, 0.6); border: 1px solid var(--glass-border); padding: 1.2rem 1.2rem 1.2rem 3.5rem; border-radius: 16px; color: white; outline: none; transition: all 0.3s ease; font-size: 1rem;"
                            onfocus="this.style.borderColor='var(--primary)'"
                            onblur="this.style.borderColor='var(--glass-border)'">
                    </div>
                </div>
                <div class="form-group">
                    <label style="display: block; margin-bottom: 0.8rem; color: #94a3b8; font-weight: 500; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em;">Return</label>
                    <div style="position: relative;">
                        <i class="fas fa-calendar-check" style="position: absolute; left: 1.2rem; top: 50%; transform: translateY(-50%); color: var(--primary);"></i>
                        <input type="date" name="endDate" required 
                            style="width: 100%; background: rgba(15, 23, 42, 0.6); border: 1px solid var(--glass-border); padding: 1.2rem 1.2rem 1.2rem 3.5rem; border-radius: 16px; color: white; outline: none; transition: all 0.3s ease; font-size: 1rem;"
                            onfocus="this.style.borderColor='var(--primary)'"
                            onblur="this.style.borderColor='var(--glass-border)'">
                    </div>
                </div>
            </div>

            <!-- Travelers -->
            <div class="form-group">
                <label style="display: block; margin-bottom: 0.8rem; color: #94a3b8; font-weight: 500; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em;">Number of Travelers</label>
                <div style="position: relative;">
                    <i class="fas fa-users" style="position: absolute; left: 1.2rem; top: 50%; transform: translateY(-50%); color: var(--primary);"></i>
                    <input type="number" name="travelers" value="1" min="1" 
                        style="width: 100%; background: rgba(15, 23, 42, 0.6); border: 1px solid var(--glass-border); padding: 1.2rem 1.2rem 1.2rem 3.5rem; border-radius: 16px; color: white; outline: none; transition: all 0.3s ease; font-size: 1.1rem;"
                        onfocus="this.style.borderColor='var(--primary)'"
                        onblur="this.style.borderColor='var(--glass-border)'">
                </div>
            </div>

            <!-- Trip Budget Section -->
            <div style="background: rgba(99, 102, 241, 0.1); border: 1px solid rgba(99, 102, 241, 0.2); padding: 1.5rem; border-radius: 20px; margin: 1rem 0;">
                <div style="display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1.5rem;">
                    <i class="fas fa-wallet" style="color: var(--primary); font-size: 1.3rem;"></i>
                    <h3 style="color: white; font-weight: 600; margin: 0;">Trip Budget</h3>
                </div>
                
                <div style="margin-bottom: 1.5rem;">
                    <label style="display: block; margin-bottom: 0.8rem; color: #cbd5e1; font-size: 0.95rem; font-weight: 500;">Total Trip Cost (USD)</label>
                    <div style="position: relative;">
                        <span style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--primary); font-weight: 600; font-size: 1.1rem;">$</span>
                        <input type="number" name="totalCost" placeholder="e.g. 5000" min="0" step="0.01"
                            style="width: 100%; background: rgba(15, 23, 42, 0.8); border: 1px solid var(--glass-border); padding: 1rem 1rem 1rem 2.5rem; border-radius: 12px; color: white; outline: none; font-size: 1.1rem;"
                            onfocus="this.style.borderColor='var(--primary)'"
                            onblur="this.style.borderColor='var(--glass-border)'">
                    </div>
                    <p style="color: var(--text-muted); font-size: 0.85rem; margin-top: 0.5rem;">Total budget for entire trip including all expenses</p>
                </div>

                <!-- Travel Style Selection -->
                <div style="margin-bottom: 1.5rem;">
                    <label style="display: block; margin-bottom: 0.8rem; color: #cbd5e1; font-size: 0.95rem; font-weight: 500;">Travel Style</label>
                    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem;">
                        <!-- Economy Option -->
                        <label style="cursor: pointer;" class="budget-option">
                            <input type="radio" name="budgetType" value="economy" style="display: none;">
                            <div style="background: rgba(34, 197, 94, 0.1); border: 2px solid rgba(34, 197, 94, 0.3); padding: 1.3rem; border-radius: 12px; text-align: center; transition: all 0.3s ease;">
                                <div style="font-size: 2rem; margin-bottom: 0.5rem;">💰</div>
                                <h3 style="color: white; font-weight: 600; margin: 0.5rem 0; font-size: 1rem;">Economy</h3>
                                <p style="color: #cbd5e1; font-size: 0.8rem; margin: 0;">Budget-friendly trips</p>
                            </div>
                        </label>

                        <!-- Moderate Option -->
                        <label style="cursor: pointer;" class="budget-option">
                            <input type="radio" name="budgetType" value="moderate" checked style="display: none;">
                            <div style="background: rgba(99, 102, 241, 0.15); border: 2px solid #6366f1; padding: 1.3rem; border-radius: 12px; text-align: center; transition: all 0.3s ease; box-shadow: 0 10px 20px rgba(99, 102, 241, 0.2);">
                                <div style="font-size: 2rem; margin-bottom: 0.5rem;">🌟</div>
                                <h3 style="color: white; font-weight: 600; margin: 0.5rem 0; font-size: 1rem;">Moderate</h3>
                                <p style="color: #cbd5e1; font-size: 0.8rem; margin: 0;">Balanced comfort</p>
                            </div>
                        </label>

                        <!-- Luxury Option -->
                        <label style="cursor: pointer;" class="budget-option">
                            <input type="radio" name="budgetType" value="luxury" style="display: none;">
                            <div style="background: rgba(236, 72, 153, 0.1); border: 2px solid rgba(236, 72, 153, 0.3); padding: 1.3rem; border-radius: 12px; text-align: center; transition: all 0.3s ease;">
                                <div style="font-size: 2rem; margin-bottom: 0.5rem;">✨</div>
                                <h3 style="color: white; font-weight: 600; margin: 0.5rem 0; font-size: 1rem;">Luxury</h3>
                                <p style="color: #cbd5e1; font-size: 0.8rem; margin: 0;">Premium experience</p>
                            </div>
                        </label>
                    </div>
                </div>
                
                

            <input type="hidden" name="costAnalysis" id="costAnalysis">

            <button type="submit" class="btn btn-primary" style="padding: 1.2rem; font-size: 1.2rem; margin-top: 1rem; border-radius: 16px; width: 100%; justify-content: center; font-weight: 600; box-shadow: 0 10px 25px -5px rgba(99, 102, 241, 0.4);">
                Create My Journey <i class="fas fa-arrow-right" style="margin-left: 0.8rem;"></i>
            </button>
        </form>
    </div>
</div>

<script>
function selectAccommodation(type, element) {
    // Remove all selected states
    document.querySelectorAll('.accommodation-option > div').forEach(el => {
        el.style.boxShadow = 'none';
        el.style.transform = 'scale(1)';
    });
    
    // Set the selected radio button
    document.querySelector(`input[name="accommodationType"][value="${type}"]`).checked = true;
    
    // Add visual feedback to selected option
    element.querySelector('div').style.boxShadow = `0 10px 25px -5px ${
        type === 'economy' ? 'rgba(34, 197, 94, 0.4)' : 
        type === 'moderate' ? 'rgba(99, 102, 241, 0.4)' : 
        'rgba(236, 72, 153, 0.4)'
    }`;
    element.querySelector('div').style.transform = 'scale(1.05)';
}

// Set initial shadow on moderate option
window.addEventListener('load', () => {
    const moderateDiv = document.querySelector('input[name="accommodationType"][value="moderate"]').closest('.accommodation-option').querySelector('div');
    if (moderateDiv) {
        moderateDiv.style.boxShadow = '0 10px 25px -5px rgba(99, 102, 241, 0.4)';
        moderateDiv.style.transform = 'scale(1.05)';
    }
});

async function analyzeCost() {
    const totalCost = parseFloat(document.querySelector('input[name="totalCost"]').value || 0);
    const budgetType = document.querySelector('input[name="budgetType"]:checked').value;
    const destination = document.querySelector('input[name="destination"]').value;
    const travelers = parseInt(document.querySelector('input[name="travelers"]').value || 1);
    
    if (totalCost === 0) {
        alert('Please enter your total trip cost');
        return;
    }
    
    if (!destination) {
        alert('Please enter a destination');
        return;
    }
    
    try {
        const response = await fetch('/travel/analyze-cost', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                totalCost,
                budgetType,
                destination,
                travelers
            })
        });
        
        const data = await response.json();
        
        if (data.success) {
            // Save analysis for dashboard display and keep it in the hidden input for trip save
            try { localStorage.setItem('lastCostAnalysis', data.analysis); } catch (e) { /* ignore */ }
            document.getElementById('costAnalysis').value = data.analysis;
            // Redirect user to dashboard to view generated output
            window.location.href = '/dashboard';
        } else {
            alert('Error: ' + (data.error || 'Failed to analyze cost'));
        }
    } catch (error) {
        console.error('Error:', error);
        alert('Failed to analyze cost. Please try again.');
    }
}

// Budget option selection visual feedback
document.addEventListener('DOMContentLoaded', function() {
    const budgetOptions = document.querySelectorAll('.budget-option');
    budgetOptions.forEach(option => {
        option.addEventListener('change', function() {
            budgetOptions.forEach(o => {
                const div = o.querySelector('div');
                if (o.querySelector('input').checked) {
                    div.style.boxShadow = '0 10px 20px rgba(99, 102, 241, 0.3)';
                    div.style.transform = 'scale(1.05)';
                } else {
                    div.style.boxShadow = 'none';
                    div.style.transform = 'scale(1)';
                }
            });
        });
    });
});
</script>

<%- include('partials/footer') %>
