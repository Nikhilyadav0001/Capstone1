<%- include('partials/header') %>

<!-- Leaflet.js for FREE MAPS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<div class="container" style="padding-top: 2rem;">
    <!-- Hero Section -->
    <div class="animate-fade" style="position: relative; height: 400px; border-radius: 32px; overflow: hidden; margin-bottom: 2rem; box-shadow: 0 20px 40px rgba(0,0,0,0.3);">
        <img src="<%= photoUrl %>" alt="<%= trip.destination %>" style="width: 100%; height: 100%; object-fit: cover;">
        <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(15, 23, 42, 0.9) 0%, transparent 60%);"></div>
        <div style="position: absolute; bottom: 2rem; left: 2rem;">
            <h1 style="font-size: 3rem; font-weight: 700; margin-bottom: 0.5rem;"><%= trip.destination %></h1>
            <p style="color: var(--text-muted); font-size: 1.2rem;">
                <i class="far fa-calendar"></i> <%= trip.dates.start.toLocaleDateString() %> - <%= trip.dates.end.toLocaleDateString() %>
                <span style="margin: 0 1rem;">|</span>
                <i class="fas fa-user-friends"></i> <%= trip.travelers %> Traveler(s)
                <span style="margin: 0 1rem;">|</span>
                <% if (trip.accommodationType === 'economy') { %>
                    <span>🏩 Economy</span>
                <% } else if (trip.accommodationType === 'luxury') { %>
                    <span>👑 Luxury</span>
                <% } else { %>
                    <span>🏨 Moderate</span>
                <% } %>
            </p>
        </div>
        
        <!-- Weather Overlay -->
        <% if (weather) { %>
        <div style="position: absolute; top: 2rem; right: 2rem;" class="glass-card">
            <div style="display: flex; align-items: center; gap: 1rem;">
                <div style="font-size: 2rem;">🌡️</div>
                <div>
                    <h3 style="font-size: 1.5rem;"><%= Math.round(weather.main.temp) %>°C</h3>
                    <p style="color: var(--text-muted); text-transform: capitalize;"><%= weather.weather[0].description %></p>
                </div>
            </div>
        </div>
        <% } %>
    </div>

    <!-- Map Section -->
    <div class="glass-card animate-fade" style="height: 300px; padding: 0; overflow: hidden; margin-bottom: 2rem; border-radius: 24px;">
        <div id="map" style="width: 100%; height: 100%;"></div>
    </div>

    <!-- Actions & Itinerary -->
    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem;">
        <div>
            <div class="glass-card animate-fade" style="margin-bottom: 2rem;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                    <h2>Itinerary</h2>
                    <% if (trip.itinerary && trip.itinerary.length === 0) { %>
                        <div style="display:flex; gap:0.75rem;">
                            <button id="generateBtn" class="btn btn-primary">
                                <i class="fas fa-wand-sparkles"></i> Generate AI Itinerary
                            </button>
                            <button id="analyzeCostBtn" class="btn btn-outline" title="Analyze trip cost with AI">
                                <i class="fas fa-calculator"></i> Analyze Cost
                            </button>
                        </div>
                    <% } %>
                </div>

                <div id="itineraryContainer">
                    <% if (trip.itinerary && trip.itinerary.length > 0) { %>
                        <% trip.itinerary.forEach(day => { %>
                            <div style="margin-bottom: 2rem; padding-left: 1.5rem; border-left: 2px solid var(--primary); position: relative;">
                                <div style="position: absolute; left: -9px; top: 0; width: 16px; height: 16px; background: var(--primary); border-radius: 50%; border: 3px solid var(--bg);"></div>
                                <h3 style="margin-bottom: 1rem; color: var(--primary);">Day <%= day.day %></h3>
                                <ul style="list-style: none; display: grid; gap: 0.8rem;">
                                    <% if (day.activities && day.activities.length > 0) { %>
                                        <% day.activities.forEach(activity => { %>
                                            <li style="background: rgba(255,255,255,0.03); padding: 1rem; border-radius: 12px; border: 1px solid var(--glass-border);">
                                                <i class="fas fa-check-circle" style="color: var(--primary); margin-right: 0.8rem;"></i>
                                                <%= activity %>
                                            </li>
                                        <% }) %>
                                    <% } %>
                                </ul>
                                <% if (day.notes) { %>
                                    <p style="margin-top: 1rem; font-style: italic; color: var(--text-muted); font-size: 0.9rem;">
                                        <strong>Pro Tip:</strong> <%= day.notes %>
                                    </p>
                                <% } %>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div style="text-align: center; padding: 3rem 0; color: var(--text-muted);">
                            <i class="fas fa-route fa-3x" style="margin-bottom: 1rem; opacity: 0.3;"></i>
                            <p>No itinerary yet. Click to let AI build one for you!</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Sidebar Tools -->
        <div style="display: flex; flex-direction: column; gap: 2rem;">
            <div class="glass-card animate-fade" style="background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(236, 72, 153, 0.1));">
                <h3 style="margin-bottom: 1rem;"><i class="fas fa-robot"></i> AI Assistant</h3>
                <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 1.5rem;">Chat with Gemini about your <%= trip.destination %> trip!</p>
                <a href="/ai/chat?city=<%= encodeURIComponent(trip.destination) %>" class="btn btn-primary" style="width: 100%; justify-content: center;">
                    Chat Now
                </a>
            </div>
            
            <form action="/travel/<%= trip._id %>/delete" method="POST">
                <button type="submit" class="btn btn-outline" style="width: 100%; color: #ef4444; border-color: #ef4444;" onclick="return confirm('Delete trip?')">
                    <i class="fas fa-trash"></i> Delete Trip
                </button>
            </form>
        </div>

        <!-- Cost Analysis Section -->
        <% if (trip.costBreakdown && Object.values(trip.costBreakdown).some(v => v > 0)) { %>
        <div class="glass-card animate-fade" style="margin-bottom: 2rem; border: 1px solid rgba(34, 197, 94, 0.3);">
            <div style="display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1.5rem;">
                <i class="fas fa-calculator" style="color: #22c55e; font-size: 1.3rem;"></i>
                <h2>Trip Cost Analysis</h2>
            </div>
            
            <!-- Accommodation Type Badge -->
            <% if (trip.accommodationType) { %>
            <div style="display: flex; gap: 1rem; margin-bottom: 1.5rem;">
                <div style="padding: 0.8rem 1.2rem; border-radius: 12px; font-weight: 600; display: flex; align-items: center; gap: 0.6rem;
                    <%= trip.accommodationType === 'economy' ? 'background: rgba(34, 197, 94, 0.2); color: #22c55e; border: 1px solid #22c55e;' : 
                        trip.accommodationType === 'luxury' ? 'background: rgba(236, 72, 153, 0.2); color: #ec4899; border: 1px solid #ec4899;' : 
                        'background: rgba(99, 102, 241, 0.2); color: #6366f1; border: 1px solid #6366f1;' %>">
                    <% if (trip.accommodationType === 'economy') { %>
                        <span style="font-size: 1.2rem;">🏩</span> Economy Stay
                    <% } else if (trip.accommodationType === 'luxury') { %>
                        <span style="font-size: 1.2rem;">👑</span> Luxury Experience
                    <% } else { %>
                        <span style="font-size: 1.2rem;">🏨</span> Moderate Comfort
                    <% } %>
                </div>
            </div>
            <% } %>
            
            <!-- Cost Breakdown Chart -->
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem; margin-bottom: 1.5rem;">
                <% const costs = trip.costBreakdown; %>
                <% if (costs.flights > 0) { %>
                <div style="background: rgba(59, 130, 246, 0.1); padding: 1rem; border-radius: 12px; text-align: center;">
                    <div style="font-size: 1.2rem; color: #3b82f6;">✈️</div>
                    <p style="color: var(--text-muted); font-size: 0.85rem; margin: 0.5rem 0 0 0;">Flights</p>
                    <p style="color: white; font-weight: 600; font-size: 1.1rem;">$<%= costs.flights.toFixed(2) %></p>
                </div>
                <% } %>
                
                <% if (costs.accommodation > 0) { %>
                <div style="background: rgba(245, 158, 11, 0.1); padding: 1rem; border-radius: 12px; text-align: center;">
                    <div style="font-size: 1.2rem;">🏨</div>
                    <p style="color: var(--text-muted); font-size: 0.85rem; margin: 0.5rem 0 0 0;">Accommodation</p>
                    <p style="color: white; font-weight: 600; font-size: 1.1rem;">$<%= costs.accommodation.toFixed(2) %></p>
                </div>
                <% } %>
                
                <% if (costs.food > 0) { %>
                <div style="background: rgba(34, 197, 94, 0.1); padding: 1rem; border-radius: 12px; text-align: center;">
                    <div style="font-size: 1.2rem;">🍽️</div>
                    <p style="color: var(--text-muted); font-size: 0.85rem; margin: 0.5rem 0 0 0;">Food & Dining</p>
                    <p style="color: white; font-weight: 600; font-size: 1.1rem;">$<%= costs.food.toFixed(2) %></p>
                </div>
                <% } %>
                
                <% if (costs.activities > 0) { %>
                <div style="background: rgba(139, 92, 246, 0.1); padding: 1rem; border-radius: 12px; text-align: center;">
                    <div style="font-size: 1.2rem;">🎭</div>
                    <p style="color: var(--text-muted); font-size: 0.85rem; margin: 0.5rem 0 0 0;">Activities</p>
                    <p style="color: white; font-weight: 600; font-size: 1.1rem;">$<%= costs.activities.toFixed(2) %></p>
                </div>
                <% } %>
                
                <% if (costs.transportation > 0) { %>
                <div style="background: rgba(236, 72, 153, 0.1); padding: 1rem; border-radius: 12px; text-align: center;">
                    <div style="font-size: 1.2rem;">🚗</div>
                    <p style="color: var(--text-muted); font-size: 0.85rem; margin: 0.5rem 0 0 0;">Transportation</p>
                    <p style="color: white; font-weight: 600; font-size: 1.1rem;">$<%= costs.transportation.toFixed(2) %></p>
                </div>
                <% } %>
                
                <% if (costs.other > 0) { %>
                <div style="background: rgba(156, 163, 175, 0.1); padding: 1rem; border-radius: 12px; text-align: center;">
                    <div style="font-size: 1.2rem;">📦</div>
                    <p style="color: var(--text-muted); font-size: 0.85rem; margin: 0.5rem 0 0 0;">Other</p>
                    <p style="color: white; font-weight: 600; font-size: 1.1rem;">$<%= costs.other.toFixed(2) %></p>
                </div>
                <% } %>
            </div>
            
            <!-- Total Cost Summary -->
            <div style="background: linear-gradient(135deg, rgba(34, 197, 94, 0.2), rgba(59, 130, 246, 0.2)); padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; text-align: center;">
                <p style="color: var(--text-muted); font-size: 0.85rem; margin: 0 0 0.5rem 0;">Total Trip Cost</p>
                <p style="color: #22c55e; font-weight: 700; font-size: 1.8rem; margin: 0;">$<%= (costs.flights + costs.accommodation + costs.food + costs.activities + costs.transportation + costs.other).toFixed(2) %></p>
                <p style="color: var(--text-muted); font-size: 0.85rem; margin: 0.5rem 0 0 0;">Per Person: $<%= ((costs.flights + costs.accommodation + costs.food + costs.activities + costs.transportation + costs.other) / trip.travelers).toFixed(2) %></p>
            </div>
            
            <% if (trip.costAnalysis) { %>
            <!-- AI Analysis Results -->
            <div style="background: rgba(34, 197, 94, 0.1); border-left: 4px solid #22c55e; padding: 1.2rem; border-radius: 8px;">
                <div style="display: flex; align-items: center; gap: 0.6rem; margin-bottom: 1rem;">
                    <i class="fas fa-lightbulb" style="color: #22c55e;"></i>
                    <h3 style="color: white; margin: 0; font-size: 1.1rem;">AI Cost Insights</h3>
                </div>
                <div style="color: #cbd5e1; line-height: 1.8; white-space: pre-wrap; font-size: 0.95rem;"><%= trip.costAnalysis %></div>
            </div>
            <% } %>
        </div>
        <% } %>

<script>
    // ──── LEAFLET MAP INITIALIZATION ────
    async function initMap() {
        try {
            const response = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent('<%= trip.destination %>')}`);
            const data = await response.json();
            
            if (data && data.length > 0) {
                const { lat, lon } = data[0];
                const map = L.map('map').setView([lat, lon], 12);
                
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '&copy; OpenStreetMap'
                }).addTo(map);
                
                L.marker([lat, lon]).addTo(map).bindPopup('<%= trip.destination %>').openPopup();
            }
        } catch (err) { console.error('Map error:', err); }
    }
    
    initMap();

    // ──── AI GENERATION ────
    const generateBtn = document.getElementById('generateBtn');
    if (generateBtn) {
        generateBtn.addEventListener('click', async () => {
            generateBtn.disabled = true;
            generateBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> AI is planning...';
            
            // Calculate days dynamically
            const start = new Date('<%= trip.dates.start %>');
            const end = new Date('<%= trip.dates.end %>');
            const diffTime = Math.abs(end - start);
            const totalDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1;

            try {
                const response = await fetch('/ai/itinerary', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        tripId: '<%= trip._id %>',
                        destination: '<%= trip.destination %>',
                        days: totalDays,
                        interests: 'sightseeing, local food, hidden gems',
                        budget: '<%= trip.budget %>',
                        travelers: <%= trip.travelers %>
                    })
                });
                
                const data = await response.json();
                if (data.success) {
                    window.location.reload();
                } else {
                    alert('Error: ' + data.error);
                    generateBtn.disabled = false;
                    generateBtn.innerHTML = 'Generate AI Itinerary';
                }
            } catch (err) {
                alert('Request failed');
                generateBtn.disabled = false;
            }
        });
    }

    // ──── ANALYZE COST ACTION ────
    const analyzeBtn = document.getElementById('analyzeCostBtn');
    if (analyzeBtn) {
        analyzeBtn.addEventListener('click', async () => {
            analyzeBtn.disabled = true;
            analyzeBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Analyzing...';

            // Determine totalCost (use trip.totalCost if available, otherwise sum breakdown)
            const tripData = {
                destination: '<%= trip.destination %>',
                travelers: <%= trip.travelers %>,
                budgetType: '<%= trip.budgetType || (trip.accommodationType || 'moderate') %>'
            };

            let totalCost = 0;
            <% if (typeof trip.totalCost !== 'undefined' && trip.totalCost !== null) { %>
                totalCost = <%= trip.totalCost %> || 0;
            <% } else { %>
                const _c = <%= JSON.stringify(trip.costBreakdown || {}) %>;
                totalCost = (_c.flights||0) + (_c.accommodation||0) + (_c.food||0) + (_c.activities||0) + (_c.transportation||0) + (_c.other||0);
            <% } %>

            try {
                const response = await fetch('/travel/analyze-cost', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        totalCost: parseFloat(totalCost),
                        budgetType: tripData.budgetType,
                        destination: tripData.destination,
                        travelers: tripData.travelers
                    })
                });

                const data = await response.json();
                if (data.success) {
                    try { localStorage.setItem('lastCostAnalysis', data.analysis); } catch (e) {}
                    // Redirect to dashboard where analysis will be shown
                    window.location.href = '/dashboard';
                } else {
                    alert('Error: ' + (data.error || 'Failed to analyze cost'));
                    analyzeBtn.disabled = false;
                    analyzeBtn.innerHTML = '<i class="fas fa-calculator"></i> Analyze Cost';
                }
            } catch (err) {
                console.error(err);
                alert('Request failed.');
                analyzeBtn.disabled = false;
                analyzeBtn.innerHTML = '<i class="fas fa-calculator"></i> Analyze Cost';
            }
        });
    }
</script>

<%- include('partials/footer') %>
